        "openweather-apis": "^4.5.0",
        "osu-parser": "git+https://github.com/LeaPhant/osu-parser.git",
        "readline-sync": "^1.4.10",
        "rosu-pp-js": "^4.0.1",
        "semver": "^7.8.5",
