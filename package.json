{
    "name": "flowabot",
    "description": "Modular Discord bot with fun features including twitch commands and advanced osu! commands.",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "git pull; npm i && [ ! -f ./config.json ] && npm run config; node checkAndRefreshToken",
        "test": "echo \"Error: no test specified\" && exit 1",
        "webui": "node renderer/webui.js",
        "commands": "node generate-commands-md",
        "config": "node generate-config",
        "emojis": "node upload-emojis"
    },
    "author": "Paraliyzed_evo",
    "repository": {
        "type": "git",
        "url": "https://github.com/Paraliyzedevo/flowabot.git"
    },
    "engines": {
        "node": ">=26.3.0 <27"
    },
    "license": "MIT",
    "dependencies": {
        "@dmzoneill/urban-dictionary": "^3.0.3",
        "@napi-rs/canvas": "^1.0.2",
        "@twurple/api": "^8.1.4",
        "@twurple/auth": "^8.1.4",
        "axios": "^1.18.1",
        "booba": "^0.0.19",
        "bparser-js": "^1.0.2",
        "chalk": "^4.1.0",
        "chart.js": "^4.5.1",
        "discord.js": "^14.26.5",
        "ffmpeg-static": "^5.3.0",
        "form-data": "^4.0.6",
        "jimp": "^0.22.12",
        "lodash": "^4.18.1",
        "luxon": "^1.28.1",
        "lzma-native": "^8.0.6",
        "mathjs": "^15.2.0",
        "mysql": "^2.18.1",
        "node-emoji": "^1.10.0",
